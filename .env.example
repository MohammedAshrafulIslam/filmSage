# Required — OpenAI API key for embeddings and chat completions
OPENAI_API_KEY=sk-xxx

# Required — Supabase project URL and API key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-supabase-anon-key

# Optional — Server port (default: 3001)
PORT=3001

# Optional — Comma-separated allowed origins for CORS (default: localhost dev servers)
# CORS_ORIGIN=https://your-app.vercel.app,https://your-domain.com
