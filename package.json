{
  "name": "filmsage",
  "version": "1.0.0",
  "description": "RAG-powered movie recommendation chatbot",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "cd server && node --watch index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cd server && node index.js"
  },
  "dependencies": {
    "vite": "^6.2.4",
    "concurrently": "^9.1.2"
  },
  "devDependencies": {}
}
